#!/usr/bin/env bash
# token-thrift: hardened CLI for sensitive codebases.
# Auto-loaded by install.sh into ~/.local/bin/token-thrift.

set -euo pipefail

THRIFT_HOME="${HOME}/.token-thrift"
GLOBAL_IGNORE="${THRIFT_HOME}/global-ignore"
LIB_DIR="${THRIFT_HOME}/lib"

unset CRG_OPENAI_API_KEY CRG_OPENAI_BASE_URL CRG_OPENAI_MODEL 2>/dev/null || true
unset CRG_OPENAI_DIMENSION CRG_OPENAI_BATCH_SIZE 2>/dev/null || true
unset GOOGLE_API_KEY MINIMAX_API_KEY 2>/dev/null || true
unset CRG_ACCEPT_CLOUD_EMBEDDINGS 2>/dev/null || true

c_red()    { printf '\033[1;31m%s\033[0m' "$*"; }
c_green()  { printf '\033[1;32m%s\033[0m' "$*"; }
c_yellow() { printf '\033[1;33m%s\033[0m' "$*"; }

# Source helper libs (graceful: missing files do not break basic operation).
[[ -f "$LIB_DIR/integrity.sh"  ]] && source "$LIB_DIR/integrity.sh"
[[ -f "$LIB_DIR/audit.sh"      ]] && source "$LIB_DIR/audit.sh"
[[ -f "$LIB_DIR/allowlist.sh"  ]] && source "$LIB_DIR/allowlist.sh"
[[ -f "$LIB_DIR/secret-scan.sh" ]] && source "$LIB_DIR/secret-scan.sh"
[[ -f "$LIB_DIR/backup.sh"     ]] && source "$LIB_DIR/backup.sh"
[[ -f "$LIB_DIR/selfupdate.sh" ]] && source "$LIB_DIR/selfupdate.sh"

# Self-integrity check (Phase 1.2).
if declare -F verify_wrapper_integrity >/dev/null 2>&1; then
    if ! verify_wrapper_integrity "$0"; then
        printf '%s wrapper SHA256 does NOT match the stored snapshot at install time.\n' \
            "$(c_red '[TAMPER]')" >&2
        printf '    The wrapper at %s may have been modified.\n' "$0" >&2
        printf '    Run: bash <token-thrift-repo>/install.sh   to reinstall, or:\n' >&2
        printf '          token-thrift self-update\n' >&2
        exit 2
    fi
fi

# MCP-config integrity check (Phase 2.5). Warning only, not fatal.
if declare -F verify_mcp_integrity >/dev/null 2>&1; then
    if ! verify_mcp_integrity "${HOME}/.claude.json"; then
        printf '%s ~/.claude.json changed since install. If you did not edit it, audit.\n' \
            "$(c_yellow '[!]')" >&2
    fi
fi

DANGER_PATTERNS=(
    "*.key" "*.pem" "*.p12" "*.pfx"
    "id_rsa*" "id_ed25519*" "id_ecdsa*"
    "wallet*.json" "keypair*.json" "*-keypair.json"
    "phantom*.json" "solflare*.json" "backpack*.json"
    ".env" "*.env" "secrets.json" "auth.json" "credentials.json"
    "*mnemonic*" "*passphrase*" "*master.key" "*seed.json" "*seed.txt"
)

show_help() {
    cat <<HELP
$(c_green 'token-thrift'): security-first code review for sensitive codebases.

USAGE:
    token-thrift build              Parse codebase (cwd) after pre-flight scan
    token-thrift update             Refresh graph after pre-flight scan
    token-thrift scan [path]        Filename-based sensitive-file scan
    token-thrift secret-scan [path] Content-level secret scan (regex inside files)
    token-thrift ext-scan [path]    Flag files with extensions outside the allowlist
    token-thrift init [path]        Install default .code-review-graphignore
    token-thrift audit [N]          Show last N (default 50) audit-log lines
    token-thrift audit-path         Print path to the audit log
    token-thrift backup [out.age]   Encrypted backup of ~/.token-thrift/
    token-thrift restore <archive>  Restore an encrypted backup
    token-thrift self-update        Update from GitHub
    token-thrift verify             Re-run integrity checks
    token-thrift status             Show graph status
    token-thrift mcp-server         Run MCP server (used by Claude Code)
    token-thrift help               Show this message
    token-thrift <other>            Pass through to underlying CLI

$(c_red 'BLOCKED:')
    install                         Auto-modifies system files. Use the bundled installer.
    apply-refactor                  Writes to source files. Use your editor instead.
    cross-repo-search               Registry has minimal validation. Path traversal risk.

$(c_yellow 'Cloud egress disabled:') GOOGLE_API_KEY, MINIMAX_API_KEY, CRG_OPENAI_*
are unset automatically. A runtime network guard also blocks known cloud
endpoints at the socket layer when the MCP server runs.
HELP
}

scan_dangerous() {
    local target="${1:-.}"
    target=$(cd "$target" 2>/dev/null && pwd) || { err_path "$1"; return 2; }

    local found=()
    local pat f rel
    for pat in "${DANGER_PATTERNS[@]}"; do
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            case "$f" in
                */node_modules/*|*/.git/*|*/.venv/*|*/venv/*|*/target/*|*/dist/*|*/build/*) continue ;;
            esac
            rel="${f#$target/}"
            found+=("$rel")
        done < <(find "$target" -name "$pat" -type f 2>/dev/null)
    done

    if [[ ${#found[@]} -gt 0 ]]; then
        printf '%s Sensitive files detected in %s:\n' "$(c_yellow '[!]')" "$target"
        local seen=""
        for r in "${found[@]}"; do
            case " $seen " in
                *" $r "*) continue ;;
            esac
            seen="$seen $r"
            printf '    - %s\n' "$r"
        done
        return 1
    fi
    printf '%s No sensitive files found in %s\n' "$(c_green '[+]')" "$target"
    return 0
}

err_path() { printf '%s Path not found: %s\n' "$(c_red '[x]')" "$1" >&2; }

ensure_local_ignore() {
    local repo="${1:-.}"
    local ignore="$repo/.code-review-graphignore"
    if [[ ! -f "$ignore" ]] && [[ -f "$GLOBAL_IGNORE" ]]; then
        cp "$GLOBAL_IGNORE" "$ignore"
        printf '%s .code-review-graphignore created from global template\n' "$(c_green '[+]')"
    fi
}

run_mcp_server() {
    local candidates=(
        "$HOME/.local/share/pipx/venvs/code-review-graph/bin/python"
        "$HOME/.local/pipx/venvs/code-review-graph/bin/python"
        "$HOME/Library/Application Support/pipx/venvs/code-review-graph/bin/python"
        "$HOME/pipx/venvs/code-review-graph/bin/python"
    )
    local p pipx_python=""
    for p in "${candidates[@]}"; do
        if [[ -x "$p" ]]; then pipx_python="$p"; break; fi
    done
    if [[ -z "$pipx_python" ]]; then
        printf '%s pipx Python for code-review-graph not found.\n' "$(c_red '[x]')" >&2
        printf '    Try: pipx reinstall code-review-graph\n' >&2
        exit 1
    fi

    local guard="$LIB_DIR/network-guard.py"
    if [[ -f "$guard" ]]; then
        # Pre-load the runtime network guard before importing the MCP server.
        exec "$pipx_python" -c "
import runpy, sys
runpy.run_path('$guard', run_name='__token_thrift_guard__')
from code_review_graph.main import main
main()
"
    fi
    exec "$pipx_python" -m code_review_graph.main
}

require_user_consent() {
    printf '\n%s Continue anyway? Type "i-accept-the-risk": ' "$(c_yellow '[?]')"
    local ans
    read -r ans
    [[ "$ans" == "i-accept-the-risk" ]] || { echo "Aborted."; exit 1; }
}

run_verify_all() {
    local fail=0
    if declare -F verify_wrapper_integrity >/dev/null 2>&1; then
        if verify_wrapper_integrity "$0"; then
            printf '%s wrapper integrity OK\n' "$(c_green '[+]')"
        else
            printf '%s wrapper integrity FAILED\n' "$(c_red '[x]')"
            fail=1
        fi
    fi
    if declare -F verify_mcp_integrity >/dev/null 2>&1; then
        if verify_mcp_integrity "${HOME}/.claude.json"; then
            printf '%s ~/.claude.json integrity OK\n' "$(c_green '[+]')"
        else
            printf '%s ~/.claude.json changed since install\n' "$(c_yellow '[!]')"
        fi
    fi
    if declare -F verify_pipx_venv >/dev/null 2>&1; then
        if verify_pipx_venv "code-review-graph"; then
            printf '%s pipx venv binaries unchanged\n' "$(c_green '[+]')"
        else
            printf '%s pipx venv binaries differ from snapshot\n' "$(c_yellow '[!]')"
        fi
    fi
    return $fail
}

# Audit every invocation (Phase 2.4) before dispatching.
declare -F audit_log >/dev/null 2>&1 && audit_log "${1:-help}" "${@:2}"

cmd="${1:-help}"
shift || true

case "$cmd" in
    help|-h|--help)
        show_help
        ;;
    install|apply-refactor|apply_refactor)
        printf '%s Subcommand "%s" is blocked by token-thrift.\n' "$(c_red '[BLOCKED]')" "$cmd" >&2
        printf '    Reason: modifies system or source code.\n' >&2
        printf '    Use the bundled installer or your editor instead.\n' >&2
        exit 1
        ;;
    cross-repo-search|cross_repo_search)
        printf '%s Subcommand "%s" is blocked by token-thrift.\n' "$(c_red '[BLOCKED]')" "$cmd" >&2
        printf '    Reason: registry validation is minimal. Path traversal risk.\n' >&2
        exit 1
        ;;
    scan)
        scan_dangerous "${1:-.}"
        ;;
    secret-scan|secret_scan)
        if declare -F scan_content_secrets >/dev/null 2>&1; then
            if scan_content_secrets "${1:-.}"; then
                printf '%s no inline secrets matched in %s\n' "$(c_green '[+]')" "${1:-.}"
            else
                printf '%s inline secret matches found above. Review before indexing.\n' "$(c_red '[x]')" >&2
                exit 1
            fi
        else
            err_path "lib/secret-scan.sh missing"
            exit 1
        fi
        ;;
    ext-scan|ext_scan)
        if declare -F scan_unknown_extensions >/dev/null 2>&1; then
            if out=$(scan_unknown_extensions "${1:-.}"); then
                printf '%s every file extension is on the allowlist\n' "$(c_green '[+]')"
            else
                printf '%s files with unknown extensions in %s:\n' "$(c_yellow '[!]')" "${1:-.}"
                printf '%s\n' "$out" | sed 's/^/    /'
                exit 1
            fi
        else
            err_path "lib/allowlist.sh missing"
            exit 1
        fi
        ;;
    init)
        target="${1:-.}"
        target=$(cd "$target" 2>/dev/null && pwd) || { err_path "${1:-.}"; exit 1; }
        ensure_local_ignore "$target"
        ;;
    audit)
        if declare -F audit_show >/dev/null 2>&1; then
            audit_show "${1:-50}"
        else
            err_path "lib/audit.sh missing"
        fi
        ;;
    audit-path|audit_path)
        if declare -F audit_path >/dev/null 2>&1; then
            audit_path
        fi
        ;;
    backup)
        if declare -F do_backup >/dev/null 2>&1; then
            do_backup "${1:-}"
        else
            err_path "lib/backup.sh missing"; exit 1
        fi
        ;;
    restore)
        if declare -F do_restore >/dev/null 2>&1; then
            do_restore "${1:?usage: token-thrift restore <archive>}"
        else
            err_path "lib/backup.sh missing"; exit 1
        fi
        ;;
    self-update|self_update|selfupdate)
        if declare -F do_selfupdate >/dev/null 2>&1; then
            do_selfupdate "$@"
        else
            err_path "lib/selfupdate.sh missing"; exit 1
        fi
        ;;
    verify)
        run_verify_all
        ;;
    build|update)
        ensure_local_ignore "$(pwd)"
        local_fail=0
        scan_dangerous "$(pwd)" || local_fail=1
        if declare -F scan_content_secrets >/dev/null 2>&1; then
            if ! scan_content_secrets "$(pwd)" >/dev/null 2>&1; then
                printf '%s inline secret patterns matched (run: token-thrift secret-scan)\n' \
                    "$(c_yellow '[!]')"
                local_fail=1
            fi
        fi
        if [[ $local_fail -ne 0 ]]; then
            printf '\n  Add the flagged files to .code-review-graphignore.\n'
            printf '  Or run:  token-thrift init\n'
            require_user_consent
        fi
        exec code-review-graph "$cmd" "$@"
        ;;
    mcp-server|mcp_server)
        run_mcp_server
        ;;
    *)
        exec code-review-graph "$cmd" "$@"
        ;;
esac
