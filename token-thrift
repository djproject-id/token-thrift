#!/usr/bin/env bash
# token-thrift — hardened wrapper around code-review-graph.
# Auto-loaded by install.sh into ~/.local/bin/token-thrift.

set -euo pipefail

THRIFT_HOME="${HOME}/.token-thrift"
GLOBAL_IGNORE="${THRIFT_HOME}/global-ignore"

unset CRG_OPENAI_API_KEY CRG_OPENAI_BASE_URL CRG_OPENAI_MODEL 2>/dev/null || true
unset CRG_OPENAI_DIMENSION CRG_OPENAI_BATCH_SIZE 2>/dev/null || true
unset GOOGLE_API_KEY MINIMAX_API_KEY 2>/dev/null || true
unset CRG_ACCEPT_CLOUD_EMBEDDINGS 2>/dev/null || true

c_red()    { printf '\033[1;31m%s\033[0m' "$*"; }
c_green()  { printf '\033[1;32m%s\033[0m' "$*"; }
c_yellow() { printf '\033[1;33m%s\033[0m' "$*"; }

DANGER_PATTERNS=(
    "*.key" "*.pem" "*.p12" "*.pfx"
    "id_rsa*" "id_ed25519*" "id_ecdsa*"
    "wallet*.json" "keypair*.json" "*-keypair.json"
    "phantom*.json" "solflare*.json" "backpack*.json"
    ".env" "*.env" "secrets.json" "auth.json" "credentials.json"
    "*mnemonic*" "*passphrase*" "*master.key" "*seed.json" "*seed.txt"
)

show_help() {
    cat <<HELP
$(c_green 'token-thrift') — hemat token, codebase Anda aman.

USAGE:
    token-thrift build              Parse codebase (cwd), pre-flight scan
    token-thrift update             Refresh graph, pre-flight scan
    token-thrift scan [path]        Scan path untuk file sensitif
    token-thrift init [path]        Pasang .code-review-graphignore default
    token-thrift status             Status graph saat ini
    token-thrift mcp-server         Jalankan MCP server (untuk Claude Code)
    token-thrift help               Tampilkan pesan ini
    token-thrift <other>            Forward ke code-review-graph

$(c_red 'BLOCKED:')
    install                         Auto-modifies sistem — pakai installer asli
    apply-refactor                  Tulis ke source — pakai Claude Code edit

$(c_yellow 'Cloud egress dimatikan:') env GOOGLE_API_KEY, MINIMAX_API_KEY,
CRG_OPENAI_* di-unset otomatis. Tool dipaksa local-only.
HELP
}

scan_dangerous() {
    local target="${1:-.}"
    target=$(cd "$target" 2>/dev/null && pwd) || { err_path "$1"; return 2; }

    local found=()
    local pat f rel
    for pat in "${DANGER_PATTERNS[@]}"; do
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            case "$f" in
                */node_modules/*|*/.git/*|*/.venv/*|*/venv/*|*/target/*|*/dist/*|*/build/*) continue ;;
            esac
            rel="${f#$target/}"
            found+=("$rel")
        done < <(find "$target" -name "$pat" -type f 2>/dev/null)
    done

    if [[ ${#found[@]} -gt 0 ]]; then
        printf '%s File sensitif terdeteksi di %s:\n' "$(c_yellow '[!]')" "$target"
        local seen=""
        for r in "${found[@]}"; do
            case " $seen " in
                *" $r "*) continue ;;
            esac
            seen="$seen $r"
            printf '    - %s\n' "$r"
        done
        return 1
    fi
    printf '%s Tidak ada file sensitif di %s\n' "$(c_green '[+]')" "$target"
    return 0
}

err_path() { printf '%s Path tidak ditemukan: %s\n' "$(c_red '[x]')" "$1" >&2; }

ensure_local_ignore() {
    local repo="${1:-.}"
    local ignore="$repo/.code-review-graphignore"
    if [[ ! -f "$ignore" ]] && [[ -f "$GLOBAL_IGNORE" ]]; then
        cp "$GLOBAL_IGNORE" "$ignore"
        printf '%s .code-review-graphignore dibuat dari template global\n' "$(c_green '[+]')"
    fi
}

run_mcp_server() {
    local candidates=(
        "$HOME/.local/share/pipx/venvs/code-review-graph/bin/python"
        "$HOME/.local/pipx/venvs/code-review-graph/bin/python"
        "$HOME/Library/Application Support/pipx/venvs/code-review-graph/bin/python"
        "$HOME/pipx/venvs/code-review-graph/bin/python"
    )
    local p
    for p in "${candidates[@]}"; do
        if [[ -x "$p" ]]; then
            exec "$p" -m code_review_graph.main
        fi
    done
    if command -v code-review-graph >/dev/null 2>&1; then
        exec code-review-graph mcp-server 2>/dev/null \
            || exec code-review-graph serve 2>/dev/null \
            || exec code-review-graph mcp 2>/dev/null \
            || true
    fi
    printf '%s Tidak menemukan Python pipx untuk code-review-graph.\n' "$(c_red '[x]')" >&2
    printf '    Coba: pipx reinstall code-review-graph\n' >&2
    exit 1
}

require_user_consent() {
    printf '\n%s Lanjut tetap? Ketik "i-accept-the-risk": ' "$(c_yellow '[?]')"
    local ans
    read -r ans
    [[ "$ans" == "i-accept-the-risk" ]] || { echo "Dibatalkan."; exit 1; }
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    help|-h|--help)
        show_help
        ;;
    install|apply-refactor|apply_refactor)
        printf '%s Subcommand "%s" diblokir oleh token-thrift.\n' "$(c_red '[BLOCKED]')" "$cmd" >&2
        printf '    Alasan: modifikasi sistem/source code.\n' >&2
        printf '    Pakai installer token-thrift, atau gunakan editor langsung.\n' >&2
        exit 1
        ;;
    cross-repo-search|cross_repo_search)
        printf '%s Subcommand "%s" diblokir oleh token-thrift.\n' "$(c_red '[BLOCKED]')" "$cmd" >&2
        printf '    Alasan: registry validation minimal — risk traversal.\n' >&2
        exit 1
        ;;
    scan)
        scan_dangerous "${1:-.}"
        ;;
    init)
        target="${1:-.}"
        target=$(cd "$target" 2>/dev/null && pwd) || { err_path "${1:-.}"; exit 1; }
        ensure_local_ignore "$target"
        ;;
    build|update)
        ensure_local_ignore "$(pwd)"
        if ! scan_dangerous "$(pwd)"; then
            printf '\n  Tambahkan file di atas ke .code-review-graphignore.\n'
            printf '  Atau jalankan: token-thrift init\n'
            require_user_consent
        fi
        exec code-review-graph "$cmd" "$@"
        ;;
    mcp-server|mcp_server)
        run_mcp_server
        ;;
    *)
        exec code-review-graph "$cmd" "$@"
        ;;
esac
